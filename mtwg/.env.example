# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key  # Never expose this client-side

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Get from: upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Amplitude ─────────────────────────────────────────────────────────────────
# Get from: analytics.amplitude.com → Settings → Projects → API Key
NEXT_PUBLIC_AMPLITUDE_KEY=your-amplitude-api-key

# ── Branch.io ─────────────────────────────────────────────────────────────────
# Get from: dashboard.branch.io → Account Settings → App
NEXT_PUBLIC_BRANCH_KEY=key_live_your-branch-key
BRANCH_SECRET=your-branch-secret  # Server-side only

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
MTWG_API_URL=http://localhost:3000
