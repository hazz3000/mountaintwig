{
  "name": "@mtwg/db",
  "version": "0.0.1",
  "private": true,
  "main":    "./src/index.ts",
  "types":   "./src/index.ts",
  "exports": {
    ".":        "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:push": 
    "db:studio":  "drizzle-kit studio",
    "db:generate":"drizzle-kit generate",
    "typecheck":  "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm":    "^0.30.0",
    "postgres":       "^3.4.0",
    "@mtwg/types":    "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit":  "^0.20.0",
    "typescript":   "^5.4.0",
    "dotenv":       "^16.4.0"
  }
}
